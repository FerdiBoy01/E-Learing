generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// ENUMS
// ==========================================

enum Role {
  STUDENT
  LECTURER
}

enum MaterialType {
  LESSON
  QUIZ
  CHALLENGE
}

enum SubmissionType {
  GITHUB
  FILE
  IMAGE
}

enum SubmissionStatus {
  PENDING
  GRADED
  REVISION
}

// 🔥 ENUM BARU UNTUK FITUR FREEMIUM & PEMBAYARAN
enum CourseType {
  REGULAR // Belajar ngoding saja (Free)
  PROJECT_BASED // Belajar buat projek (Berbayar)
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  EXPIRED
}

// ==========================================
// MODELS
// ==========================================

model User {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  password_hash String
  role          Role     @default(STUDENT)
  nim_nip       String? // Opsional
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  avatar_url String?
  profession String? // Contoh: "Senior Web Developer" atau "Dosen Sistem Informasi"
  bio        String? // Penjelasan singkat tentang pengalaman dosen

  // 🔥 TAMBAHAN UNTUK FITUR GAMIFIKASI:
  exp Int @default(0) // Tabungan EXP mahasiswa

  courses     Course[] // Relasi untuk Dosen yang membuat course
  progress    StudentProgress[]
  submissions Submission[]
  enrollments Enrollment[] // Relasi buat nyatet kelas apa aja yang diambil

  // 🔥 TAMBAHAN: Relasi untuk riwayat transaksi
  transactions Transaction[]

  @@map("users")
}

model Course {
  id            String  @id @default(uuid())
  title         String
  description   String?
  thumbnail_url String?
  status        String  @default("ACTIVE")

  // 🔥 TAMBAHAN: Tipe course dan harga
  type  CourseType @default(REGULAR)
  price Int        @default(0) // Kalau 0 berarti gratis

  lecturer_id String
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  lecturer    User         @relation(fields: [lecturer_id], references: [id])
  chapters    Chapter[]
  enrollments Enrollment[] // Relasi buat ngitung jumlah MHS

  // 🔥 TAMBAHAN: Relasi ke transaksi pembelian
  transactions Transaction[]

  @@map("courses")
}

// 🔥 MODEL BARU: TRANSAKSI PEMBELIAN COURSE
model Transaction {
  id         String        @id @default(uuid())
  student_id String
  course_id  String
  amount     Int // Harga saat dibeli (untuk jaga-jaga kalau harga course berubah nanti)
  status     PaymentStatus @default(PENDING)

  // URL untuk halaman pembayaran (nanti bisa diisi link Midtrans)
  payment_url String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  student User   @relation(fields: [student_id], references: [id], onDelete: Cascade)
  course  Course @relation(fields: [course_id], references: [id], onDelete: Cascade)

  @@map("transactions")
}

// MODEL: ENROLLMENT (KRS-AN MAHASISWA)
model Enrollment {
  id           String    @id @default(uuid())
  student_id   String
  course_id    String
  progress     Int       @default(0) // Persentase belajar (0-100)
  is_completed Boolean   @default(false) // Udah lulus belum?
  enrolled_at  DateTime  @default(now())
  completed_at DateTime? // Tanggal lulus buat di Sertifikat

  student User   @relation(fields: [student_id], references: [id], onDelete: Cascade)
  course  Course @relation(fields: [course_id], references: [id], onDelete: Cascade)

  // Pastikan 1 mahasiswa cuma bisa ambil 1 kelas yang sama 1 kali
  @@unique([student_id, course_id])
  @@map("enrollments")
}

model Chapter {
  id          String   @id @default(uuid())
  course_id   String
  title       String
  order_index Int
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  course    Course     @relation(fields: [course_id], references: [id], onDelete: Cascade)
  materials Material[]

  @@map("chapters")
}

model Material {
  id          String       @id @default(uuid())
  chapter_id  String
  title       String
  type        MaterialType
  content     String? // Bisa berisi markdown atau JSON string
  order_index Int
  created_at  DateTime     @default(now())
  updated_at  DateTime     @updatedAt

  chapter     Chapter           @relation(fields: [chapter_id], references: [id], onDelete: Cascade)
  progress    StudentProgress[]
  submissions Submission[]

  @@map("materials")
}

model StudentProgress {
  id           String    @id @default(uuid())
  student_id   String
  material_id  String
  is_completed Boolean   @default(false)
  completed_at DateTime?

  student  User     @relation(fields: [student_id], references: [id], onDelete: Cascade)
  material Material @relation(fields: [material_id], references: [id], onDelete: Cascade)

  @@unique([student_id, material_id]) // Satu student hanya punya 1 progress per material
  @@map("student_progress")
}

model Submission {
  id          String @id @default(uuid())
  student_id  String
  material_id String

  submission_type SubmissionType?
  submission_url  String // Tautan GitHub (Wajib)
  image_url       String? // Untuk Screenshot (Opsional)

  status       SubmissionStatus @default(PENDING)
  score        Int?
  feedback     String?
  submitted_at DateTime         @default(now())
  updated_at   DateTime         @updatedAt

  student  User     @relation(fields: [student_id], references: [id], onDelete: Cascade)
  material Material @relation(fields: [material_id], references: [id], onDelete: Cascade)

  @@map("submissions")
}
