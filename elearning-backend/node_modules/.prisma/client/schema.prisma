generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// ENUMS (STANDARISASI MARKETPLACE)
// ==========================================

enum Role {
  STUDENT // Mahasiswa / Pembelajar umum
  LECTURER // Dosen (Bikin kelas privat dengan access code)
  CREATOR // Programmer (Bikin kelas publik/jualan)
  ADMIN // Pengelola NusaLearn
}

enum CourseVisibility {
  PUBLIC // Muncul di katalog (Bisa dibeli / diambil gratis)
  PRIVATE // Sembunyi dari katalog (Butuh access code dari dosen)
}

enum CourseType {
  REGULAR // Kelas teori/fundamental
  PROJECT_BASED // Kelas premium bangun portfolio nyata
}

enum MaterialType {
  LESSON
  QUIZ
  CHALLENGE
}

enum SubmissionType {
  GITHUB
  FILE
  IMAGE
}

enum SubmissionStatus {
  PENDING
  GRADED
  REVISION
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  EXPIRED
}

// 🔥 TAMBAHAN BARU: Status Kurasi Admin
enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

// ==========================================
// MODELS
// ==========================================

model User {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  password_hash String
  role          Role     @default(STUDENT)
  nim_nip       String? // Opsional (Bisa NIM Mahasiswa atau NIP Dosen)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  avatar_url String?
  profession String? // Contoh: "Senior Web Developer", "Dosen UI"
  bio        String? @db.Text

  // 🔥 Fitur Gamifikasi & Saldo Kreator
  exp     Int @default(0) // Tabungan EXP mahasiswa
  level   Int @default(1) // Level Mahasiswa (Naik tiap kelipatan 1000 EXP)
  points  Int @default(0) // Mata uang virtual hasil lulus kelas
  balance Int @default(0) // Saldo penghasilan CREATOR dari jualan kelas

  courses      Course[] // Kelas yang dibuat (Dosen/Kreator)
  progress     StudentProgress[]
  submissions  Submission[]
  enrollments  Enrollment[]
  transactions Transaction[]

  // 🔥 RELASI BARU: Histori pembelian materi eceran
  material_unlocks MaterialUnlock[]

  @@map("users")
}

model Course {
  id            String  @id @default(uuid())
  title         String
  description   String? @db.Text
  thumbnail_url String?

  // 🔥 TAMBAHAN BARU: Status Approval QC Admin
  status ApprovalStatus @default(PENDING)

  // Mode Publikasi & Visibilitas
  is_published Boolean          @default(false) // True = Rilis, False = Draft
  visibility   CourseVisibility @default(PUBLIC)
  access_code  String?          @unique // Kode token untuk join kelas PRIVATE

  // Tipe & Monetisasi
  type  CourseType @default(REGULAR)
  price Int        @default(0) // Harga IDR asli (0 = Gratis)

  // 🔥 Reward Gamifikasi
  reward_points Int @default(0) // Poin gratis buat modal beli kelas premium
  reward_exp    Int @default(500) // EXP yang didapat pas lulus kelas

  lecturer_id String
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  lecturer     User          @relation(fields: [lecturer_id], references: [id])
  chapters     Chapter[]
  enrollments  Enrollment[]
  transactions Transaction[]

  @@index([lecturer_id])
  @@index([visibility, is_published])
  @@map("courses")
}

model Transaction {
  id         String        @id @default(uuid())
  student_id String
  course_id  String
  amount     Int // Harga saat dibeli (bisa harga IDR atau harga Poin)
  status     PaymentStatus @default(PENDING)

  // Kesiapan Gateway (Midtrans/Xendit)
  payment_url       String?
  gateway_reference String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  student User   @relation(fields: [student_id], references: [id], onDelete: Cascade)
  course  Course @relation(fields: [course_id], references: [id], onDelete: Cascade)

  @@index([student_id])
  @@index([course_id])
  @@map("transactions")
}

model Enrollment {
  id           String    @id @default(uuid())
  student_id   String
  course_id    String
  progress     Int       @default(0)
  is_completed Boolean   @default(false)
  enrolled_at  DateTime  @default(now())
  completed_at DateTime?

  student User   @relation(fields: [student_id], references: [id], onDelete: Cascade)
  course  Course @relation(fields: [course_id], references: [id], onDelete: Cascade)

  @@unique([student_id, course_id])
  @@index([student_id])
  @@index([course_id])
  @@map("enrollments")
}

model Chapter {
  id          String   @id @default(uuid())
  course_id   String
  title       String
  order_index Int
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  course    Course     @relation(fields: [course_id], references: [id], onDelete: Cascade)
  materials Material[]

  @@index([course_id])
  @@map("chapters")
}

model Material {
  id          String       @id @default(uuid())
  chapter_id  String
  title       String
  type        MaterialType
  content     String?      @db.Text
  order_index Int

  is_free_preview Boolean @default(false)

  // 🔥 TAMBAHAN BARU: Harga untuk buka materi secara eceran pakai Nusa Points
  unlock_points Int @default(3000)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  chapter     Chapter           @relation(fields: [chapter_id], references: [id], onDelete: Cascade)
  progress    StudentProgress[]
  submissions Submission[]

  // 🔥 RELASI BARU: Histori pembelian eceran untuk materi ini
  unlocks MaterialUnlock[]

  @@index([chapter_id])
  @@map("materials")
}

// ==================================================
// 🔥 TABEL BARU: Transaksi Pembelian Materi Eceran
// ==================================================
model MaterialUnlock {
  id          String   @id @default(uuid())
  user_id     String
  material_id String
  unlocked_at DateTime @default(now())

  // Relasi
  user     User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  material Material @relation(fields: [material_id], references: [id], onDelete: Cascade)

  // Mencegah user beli materi yang sama berkali-kali
  @@unique([user_id, material_id])
  @@map("material_unlocks")
}

model StudentProgress {
  id           String    @id @default(uuid())
  student_id   String
  material_id  String
  is_completed Boolean   @default(false)
  completed_at DateTime?

  student  User     @relation(fields: [student_id], references: [id], onDelete: Cascade)
  material Material @relation(fields: [material_id], references: [id], onDelete: Cascade)

  @@unique([student_id, material_id])
  @@index([student_id])
  @@index([material_id])
  @@map("student_progress")
}

model Submission {
  id          String @id @default(uuid())
  student_id  String
  material_id String

  submission_type SubmissionType?
  submission_url  String
  image_url       String?

  status   SubmissionStatus @default(PENDING)
  score    Int?
  feedback String?          @db.Text

  submitted_at DateTime @default(now())
  updated_at   DateTime @updatedAt

  student  User     @relation(fields: [student_id], references: [id], onDelete: Cascade)
  material Material @relation(fields: [material_id], references: [id], onDelete: Cascade)

  @@index([student_id])
  @@index([material_id])
  @@index([status])
  @@map("submissions")
}
